{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
    ':disableRateLimiting',
    ':dependencyDashboard',
    ':semanticCommits',
    ':automergeBranch',
    'github>thaynes43/haynes-ops//.renovate/autoMerge.json5',
    'github>thaynes43/haynes-ops//.renovate/groups.json5',
    'github>thaynes43/haynes-ops//.renovate/semanticCommits.json5',
    'github>thaynes43/haynes-ops//.renovate/labels.json5',
    'github>thaynes43/haynes-ops//.renovate/customManagers.json5',
  ],
  dependencyDashboard: true,
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  suppressNotifications: [
    'prEditedNotification',
    'prIgnoreNotification',
  ],
  rebaseWhen: 'conflicted',
  timezone: 'America/New_York',
  schedule: [
    // Nightly window (local time). A release still soaks per
    // minimumReleaseAge (3 days for third-party), then lands here while the
    // cluster is idle — instead of waiting for the weekend. Widened from the
    // original 2–6am: Mend's hosted run cadence did not reliably land inside
    // that narrow 4h window, so PRs went un-re-evaluated overnight.
    'after 10pm and before 6am',
  ],
  ignorePaths: [
    '**/*.sops.*',
    '**/bootstrap/**',
    'kubernetes/edge/bootstrap/**',
    'kubernetes/edge/flux/repositories/**',
    '.archive/**',
  ],
  flux: {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/',
    ],
  },
  'helm-values': {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/',
    ],
  },
  helmfile: {
    managerFilePatterns: [
      '/(^|/)helmfile\\.ya?ml(?:\\.j2)?$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/',
    ],
  },
  kustomize: {
    managerFilePatterns: [
      '/(^|/)kustomization\\.ya?ml(?:\\.j2)?$/',
    ],
  },
  pip_requirements: {
    managerFilePatterns: [
      '/(^|/)[\\w-]*requirements(-\\w+)?\\.(txt|pip)(?:\\.j2)?$/',
    ],
  },
  commitMessageTopic: '{{depName}}',
  commitMessageExtra: 'to {{newVersion}}',
  commitMessageSuffix: '',
}
