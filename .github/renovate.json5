{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
    ':disableRateLimiting',
    ':dependencyDashboard',
    ':semanticCommits',
    // PR-based auto-merge (NOT :automergeBranch). flux-local runs on pull_request
    // only, so branch-mode merges deadlocked — green PRs never merged. With PR mode
    // + platformAutomerge, GitHub merges each eligible PR when flux-local passes,
    // independent of Mend's hosted cadence, and leaves a visible merged-PR record.
    ':automergePr',
    'github>thaynes43/haynes-ops//.renovate/autoMerge.json5',
    'github>thaynes43/haynes-ops//.renovate/groups.json5',
    'github>thaynes43/haynes-ops//.renovate/semanticCommits.json5',
    'github>thaynes43/haynes-ops//.renovate/labels.json5',
    'github>thaynes43/haynes-ops//.renovate/customManagers.json5',
    // Holds registry LAST — reasoned release blacklist (allowedVersions + WHY).
    // Later rules win per-dependency, so a hold here is the final word for that
    // package even over an auto-merge allowlist. See docs/renovate/README.md.
    'github>thaynes43/haynes-ops//.renovate/holds.json5',
  ],
  dependencyDashboard: true,
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  suppressNotifications: [
    'prEditedNotification',
    'prIgnoreNotification',
  ],
  rebaseWhen: 'conflicted',
  // Use GitHub-native auto-merge: the PR merges itself the moment the required
  // flux-local check passes, without waiting for Renovate's next hosted run.
  platformAutomerge: true,
  timezone: 'America/New_York',
  schedule: [
    'after 10pm',
    'before 6am',
  ],
  ignorePaths: [
    '**/*.sops.*',
    '**/bootstrap/**',
    'kubernetes/edge/bootstrap/**',
    'kubernetes/edge/flux/repositories/**',
    // Both archive folders are frozen, decommissioned configs — never update them.
    // `.archive/` (older) + `archive/` (added 2026-06); the latter was leaking
    // PRs (terraform/compose bumps under archive/alumni/) until added here.
    '.archive/**',
    'archive/**',
  ],
  flux: {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/',
    ],
  },
  'helm-values': {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/',
    ],
  },
  helmfile: {
    managerFilePatterns: [
      '/(^|/)helmfile\\.ya?ml(?:\\.j2)?$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/',
    ],
  },
  kustomize: {
    managerFilePatterns: [
      '/(^|/)kustomization\\.ya?ml(?:\\.j2)?$/',
    ],
  },
  pip_requirements: {
    managerFilePatterns: [
      '/(^|/)[\\w-]*requirements(-\\w+)?\\.(txt|pip)(?:\\.j2)?$/',
    ],
  },
  commitMessageTopic: '{{depName}}',
  commitMessageExtra: 'to {{newVersion}}',
  commitMessageSuffix: '',
}
