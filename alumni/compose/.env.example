# Documents required env vars. The real .env is generated by scripts/load-secrets.sh
# from GCP Secret Manager — never commit values to this file.

SECRET_KEY=                   # outline-secret-key (32-byte hex)
UTILS_SECRET=                 # outline-utils-secret (32-byte hex)
POSTGRES_PASSWORD=            # outline-postgres-password
REDIS_PASSWORD=               # outline-redis-password
GOOGLE_CLIENT_ID=             # outline-oauth-client-id
GOOGLE_CLIENT_SECRET=         # outline-oauth-client-secret

# Optional — leave empty until configured
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=                # outline-smtp-password
SMTP_FROM_EMAIL=
